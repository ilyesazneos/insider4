case "${1:-connect}" in
  connect) connect ;;
  config) configure ;;
  key|ssh-key) setup_key ;;
  pull-backup|pull) pull_backup ;;
  backup|sv) backup ;;
  status) status ;;
  doctor) doctor ;;
  reset) reset_config ;;
  target|ssh|host) set_value target "${2:-}" ;;
  project|dir) set_value project "${2:-}" ;;
  port) set_value port "${2:-}" ;;
  backup-port) set_value backup-port "${2:-}" ;;
  front) set_value front "${2:-}" ;;
  back|backend) set_value back "${2:-}" ;;
  backup-dir|local-backup-dir) set_value backup-dir "${2:-}" ;;
  help|-h|--help) help ;;
  *) fail "Unknown command: $1. Try: insider4 help" ;;
esac
