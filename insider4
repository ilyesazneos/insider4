connect() {
  load_config

  need ssh
  need nc
  need python3

  write_config "$SSH_TARGET" "$PORT" "$BACKUP_PORT" "$PROJECT_DIR" "$FRONT_SERVICE" "$BACK_SERVICE" "$LOCAL_BACKUP_DIR"

  local copy_cmd
  copy_cmd="$(clipboard_command)"

  start_clipboard_receiver "$PORT" "$copy_cmd"
  start_backup_receiver "$BACKUP_PORT" "$LOCAL_BACKUP_DIR"
  # Backups are pulled with scp; no long-running backup receiver.

  cleanup() {
    echo
    echo "[$APP] Closing local channels..."
    kill "${CLIP_PID:-}" 2>/dev/null || true
    kill "${BACKUP_PID:-}" 2>/dev/null || true
  }
  trap cleanup EXIT INT TERM

  local rs
  rs="$(remote_bootstrap_script)"

  echo
  echo "[$APP] Connecting with one SSH session."
  echo "[$APP] Project directory: $PROJECT_DIR"
  echo "[$APP] Clipboard port: $PORT"
  echo "[$APP] Backup mode: code-only archive, pull with scp"
  echo "[$APP] Enter your SSH password if prompted."
  echo

  ssh -t \
    -R "127.0.0.1:${PORT}:127.0.0.1:${PORT}" \
    -R "127.0.0.1:${BACKUP_PORT}:127.0.0.1:${BACKUP_PORT}" \
    "$SSH_TARGET" \
    "INSIDER4_PROJECT_DIR=$(printf "%q" "$PROJECT_DIR") INSIDER4_FRONT_SERVICE=$(printf "%q" "$FRONT_SERVICE") INSIDER4_BACK_SERVICE=$(printf "%q" "$BACK_SERVICE") INSIDER4_PORT=$(printf "%q" "$PORT") INSIDER4_BACKUP_PORT=$(printf "%q" "$BACKUP_PORT") bash -lc $(printf "%q" "$rs")"
}

pull_backup() {
  load_config
  need ssh
  need scp

  local local_dir remote_path file_name
  local_dir="$(expand_local_dir "$LOCAL_BACKUP_DIR")"
  mkdir -p "$local_dir"

  remote_path="$(ssh "$SSH_TARGET" 'cat ~/.insider4-last-backup 2>/dev/null || true')"
  remote_path="$(printf "%s" "$remote_path" | tr -d "\r" | head -n 1)"

  [ -n "$remote_path" ] || fail "No remote backup found. Run SV first."

  case "$remote_path" in
    /tmp/*.tar.gz) ;;
    *) fail "Refusing suspicious remote backup path: $remote_path" ;;
  esac

  file_name="$(basename "$remote_path")"

  echo "[$APP] Pulling backup with scp."
  echo "[$APP] Remote: $remote_path"
  echo "[$APP] Local:  $local_dir/$file_name"

  scp "$SSH_TARGET:$remote_path" "$local_dir/"

  echo "[$APP] Backup pulled:"
  ls -lh "$local_dir/$file_name"
}

backup() {
  load_config
  need ssh

  echo "[$APP] Creating code-only backup remotely..."
  ssh -t "$SSH_TARGET" 'bash -lc "source ~/.bashrc && SV"'

  echo
  pull_backup
}


doctor() {
  echo "[$APP] Doctor"
  echo

  local ok=1

  check_cmd() {
    if command -v "$1" >/dev/null 2>&1; then
      echo "OK   command: $1"
    else
      echo "MISS command: $1"
      ok=0
    fi
  }

  check_cmd bash
  check_cmd ssh
  check_cmd nc
  check_cmd python3

  if command -v xclip >/dev/null 2>&1 || command -v wl-copy >/dev/null 2>&1 || command -v pbcopy >/dev/null 2>&1 || command -v clip.exe >/dev/null 2>&1; then
    echo "OK   clipboard tool"
  else
    echo "MISS clipboard tool: install xclip, wl-clipboard, pbcopy, or clip.exe"
    ok=0
  fi

  if command -v ssh-copy-id >/dev/null 2>&1; then
    echo "OK   ssh-copy-id"
  else
    echo "WARN ssh-copy-id missing: insider4 key may not work"
  fi

  echo
  echo "===== Config files ====="

  if [ -f "$CONFIG_FILE" ]; then
    echo "OK   insider4 config: $CONFIG_FILE"
  else
    echo "MISS insider4 config: run insider4 config"
    ok=0
  fi

  if [ -f "$PAPIER2_CONFIG_FILE" ]; then
    echo "OK   papier2-compatible config: $PAPIER2_CONFIG_FILE"
  else
    echo "MISS papier2-compatible config: run insider4 config"
    ok=0
  fi

  echo
  echo "===== Config validation ====="

  if [ -f "$CONFIG_FILE" ]; then
    SSH_TARGET=""
    PORT="$DEFAULT_PORT"
    BACKUP_PORT="$DEFAULT_BACKUP_PORT"
    PROJECT_DIR="$DEFAULT_PROJECT_DIR"
    FRONT_SERVICE="$DEFAULT_FRONT_SERVICE"
    BACK_SERVICE="$DEFAULT_BACK_SERVICE"
    LOCAL_BACKUP_DIR="$DEFAULT_LOCAL_BACKUP_DIR"

    set +e
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
    local source_status=$?
    set -e

    if [ "$source_status" -eq 0 ] && config_looks_valid; then
      echo "OK   insider4 config is valid"
      echo "INFO target: $SSH_TARGET"
      echo "INFO project: $PROJECT_DIR"
      echo "INFO frontend service: $FRONT_SERVICE"
      echo "INFO backend service: $BACK_SERVICE"
      echo "INFO local backup dir: ${LOCAL_BACKUP_DIR#\\}"
    else
      echo "BAD  insider4 config is invalid: run insider4 config"
      ok=0
    fi
  fi

  echo
  if [ "$ok" -eq 1 ]; then
    echo "[$APP] Doctor OK."
  else
    echo "[$APP] Doctor found issues."
    return 1
  fi
}


status() {
  echo "[$APP] config:"
  if [ -f "$CONFIG_FILE" ]; then
    cat "$CONFIG_FILE"
  else
    echo "No config found."
  fi

  echo
  echo "[$APP] compatible papier2 config:"
  if [ -f "$PAPIER2_CONFIG_FILE" ]; then
    cat "$PAPIER2_CONFIG_FILE"
  else
    echo "No papier2 config found."
  fi
}

reset_config() {
  rm -f "$CONFIG_FILE" "$PAPIER2_CONFIG_FILE"
  echo "[$APP] Config deleted."
  echo "[$APP] Compatible papier2 config deleted."
}

help() {
  cat <<'HELP'
insider4 — AI-assisted remote development workflow

INSIDER4 is the parent workflow.
It configures SSH, clipboard, project directory, Docker services and a secure code-only backup tunnel.
It also writes a compatible papier2 config.

