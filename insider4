I4DOCTOR() {
  echo "[insider4] Remote doctor"
  echo

  local ok=1

  check_cmd() {
    if command -v "$1" >/dev/null 2>&1; then
      echo "OK   command: $1"
    else
      echo "MISS command: $1"
      ok=0
    fi
  }

  check_cmd bash
  check_cmd git
  check_cmd docker
  check_cmd python3
  check_cmd nc
  check_cmd tar

  echo
  echo "===== Project ====="
  echo "Project: $INSIDER4_PROJECT_DIR"

  if _i4_root; then
    echo "OK   project directory"
  else
    echo "BAD  project directory"
    ok=0
  fi

  echo
  echo "===== Git ====="
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "OK   git repository"
    git status --short || true
  else
    echo "WARN not a git repository"
  fi

  echo
  echo "===== Docker Compose ====="
  if docker compose ps --services >/dev/null 2>&1; then
    echo "OK   docker compose"
    docker compose ps --services
  else
    echo "WARN docker compose not available or no compose file here"
  fi

  echo
  if [ "$ok" -eq 1 ]; then
    echo "[insider4] Remote doctor OK."
  else
    echo "[insider4] Remote doctor found issues."
    return 1
  fi
}


